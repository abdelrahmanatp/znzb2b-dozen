# Dozen Hotel Supplies AI System — Environment Variables
# Copy this file to .env and fill in real values before running any tool.
# Never commit .env to version control.

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Sheets ──────────────────────────────────────────────────────────
# Paste the full JSON content of the service account key (one line, escaped)
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# The Spreadsheet ID from the Google Sheets URL
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# ── Google Maps API ────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Email / SendGrid ───────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
# Sending domain — use dedicated outreach subdomain (e.g. outreach.dozensupplies.com)
EMAIL_FROM_ADDRESS=outreach@dozensupplies.com
EMAIL_FROM_NAME=Dozen Hotel Supplies

# ── Vector Store ──────────────────────────────────────────────────────────
# Option A: Local ChromaDB (no API key needed — set path only)
VECTOR_STORE_PATH=./chroma_db
# Option B: Pinecone (cloud) — comment out ChromaDB path if using Pinecone
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_INDEX_NAME=dozen-catalog

# ── WhatsApp Business API (Phase 2 — not needed for Sprint 1) ─────────────
# Apply at: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# Account: +255 772 502 076 (primary) / +255 773 808 718 (secondary)
WABA_PHONE_NUMBER_ID=your_waba_phone_number_id_here
WABA_ACCESS_TOKEN=your_waba_access_token_here
